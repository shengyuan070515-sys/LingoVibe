# ────────────────────────────────────────────────────────────────────────────
# LingoVibe 环境变量说明
# 复制为 .env（本地）或在 Vercel 项目 Settings → Environment Variables 中配置
# ────────────────────────────────────────────────────────────────────────────

# 【必填】前端：部署后的站点根 URL（含 https，无末尾斜杠）
# 本地联调时填 http://localhost:3000（vercel dev 默认端口）
VITE_READING_API_BASE=https://your-project.vercel.app

# ────────────────────────────────────────────────────────────────────────────
# Serverless 环境变量（Vercel 服务端，不会暴露给浏览器）
# ────────────────────────────────────────────────────────────────────────────

# 【必填】AI 代理 - DeepSeek API Key（Emma 对话 / 生词查词 / 阅读分析）
# 在 https://platform.deepseek.com 获取
DEEPSEEK_API_KEY=sk-xxxxxxxx

# 【必填】每日阅读「联网搜索」- Tavily API Key
# 在 https://tavily.com 获取
TAVILY_API_KEY=tvly-xxxxxxxx

# 【可选】Google Cloud Text-to-Speech（/api/tts）
# 在 GCP 控制台创建 Service Account 并下载密钥，整段 JSON 粘贴为单行
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}
# TTS_VOICE_NAME=en-US-Neural2-J
# TTS_LANGUAGE_CODE=en-US
# TTS_SPEAKING_RATE=1

# 【可选】Vercel KV / Upstash（每日精选 8 篇缓存）
# 在 Vercel 项目 Storage 中创建后自动注入，或手动填写
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# 【可选】本地调试：无 KV 时设为 1，跳过读写缓存
# READING_FEATURED_SKIP_KV=1

# 【可选】Vercel Cron 鉴权密钥（自行生成长随机串）
# CRON_SECRET=

# ────────────────────────────────────────────────────────────────────────────
# 前端可选配置（VITE_ 前缀，会打包进客户端）
# ────────────────────────────────────────────────────────────────────────────

# 【可选】Unsplash 图片搜索 Access Key
# 不配置时生词卡片使用占位图，核心功能不受影响
# 在 https://unsplash.com/developers 申请（免费额度够用）
# VITE_UNSPLASH_ACCESS_KEY=your-unsplash-access-key
