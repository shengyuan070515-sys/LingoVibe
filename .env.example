# 前端：部署 Serverless 后的站点根 URL（含 https，无末尾斜杠）
VITE_READING_API_BASE=https://your-project.vercel.app

# Serverless（Vercel / vercel dev）：每日阅读「联网搜索」用 Tavily，勿提交到 Git
# 在 https://tavily.com 获取 API Key
TAVILY_API_KEY=tvly-xxxxxxxx

# Vercel KV / Upstash（每日精选 8 篇缓存）。在 Vercel 项目 Storage 或 Integrations 中创建后自动注入，或手动填写 REST 地址与 Token
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Vercel Cron 调用 /api/reading-featured-cron 时的 Bearer 密钥（自行生成长随机串）
# CRON_SECRET=
